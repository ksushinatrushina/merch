generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LedgerEntryType {
  ADMIN_GRANT
  ADMIN_DEBIT
  GIFT_SENT
  GIFT_RECEIVED
  ORDER_DEBIT
  ORDER_REFUND
}

enum OrderStatus {
  CREATED
  APPROVED
  FULFILLED
  CANCELED
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  role               Role               @default(EMPLOYEE)
  coinBalance        Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  ledgerEntries      CoinLedgerEntry[]  @relation("userLedger")
  sentGifts          CoinLedgerEntry[]  @relation("giftSender")
  receivedOrders     Order[]
  monthlyGiftQuotas  MonthlyGiftQuota[]
}

model MonthlyGiftQuota {
  id            String   @id @default(cuid())
  userId        String
  year          Int
  month         Int
  sentCoins     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
}

model CoinLedgerEntry {
  id              String          @id @default(cuid())
  userId          String
  type            LedgerEntryType
  amount          Int
  description     String
  relatedUserId   String?
  orderId         String?
  createdAt       DateTime        @default(now())
  user            User            @relation("userLedger", fields: [userId], references: [id], onDelete: Cascade)
  relatedUser     User?           @relation("giftSender", fields: [relatedUserId], references: [id])
  order           Order?          @relation(fields: [orderId], references: [id])

  @@index([userId, createdAt])
}

model MerchItem {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  description  String
  priceCoins   Int
  stock        Int
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
}

model Order {
  id            String           @id @default(cuid())
  userId        String
  status        OrderStatus      @default(CREATED)
  totalCoins    Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  ledgerEntries CoinLedgerEntry[]
}

model OrderItem {
  id           String    @id @default(cuid())
  orderId      String
  merchItemId  String
  quantity     Int
  unitPrice    Int
  createdAt    DateTime  @default(now())
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  merchItem    MerchItem @relation(fields: [merchItemId], references: [id], onDelete: Restrict)
}
